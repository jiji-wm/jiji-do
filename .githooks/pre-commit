#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR=$(dirname "$(readlink -f "$0")")

# 1) rustfmt check.
if ! cargo fmt --all -- --check; then
    cat >&2 <<'MSG'

✖ rustfmt check failed.
  Run:  cargo fmt --all
  Then re-stage and re-commit.

MSG
    exit 1
fi

# 2) Internal-reference check on staged code.
"$HOOK_DIR/check-no-dd-refs.sh" --staged
